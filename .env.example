# ── Server ────────────────────────────────────────────────────────────────────
ML_HOST=0.0.0.0
ML_PORT=9000

# ── Model selection ───────────────────────────────────────────────────────────
# On a GPU server set WHISPER_MODEL=large-v3
SBERT_MODEL=all-mpnet-base-v2
WHISPER_MODEL=medium

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Files are uploaded by the backend service and stored in S3.
# ML downloads them here using just the S3 key it receives in the request.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2
S3_BUCKET=resume-screener-uploads

# ── Cloudinary (alternative to S3 — set USE_CLOUDINARY=true to switch) ────────
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Database ──────────────────────────────────────────────────────────────────
# ML connects to the SAME postgres as the backend to look up s3_key by record ID
# and to write back results (embeddings, scores, transcripts).
# Point this at whichever postgres instance the backend is using.
DATABASE_URL=postgresql+psycopg2://resume_user:change-me-strong-password@localhost:5432/resume_db

# ── Temp files ────────────────────────────────────────────────────────────────
TMP_DIR=/tmp/ml_uploads
MAX_FILE_SIZE_MB=200
